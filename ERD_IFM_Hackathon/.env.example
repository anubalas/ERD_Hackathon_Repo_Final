ANTHROPIC_API_KEY=           # Claude API key — never commit to git
OPENAI_API_KEY=  # GenEngine API key
REDIS_URL=redis://localhost:6379
REDIS_CHANNEL=telemetry
SQLITE_DB_PATH=./ifm_audit.db
ANOMALY_THRESHOLD=0.0        # IsolationForest decision_function threshold (0.0 = default)
CHROMA_PERSIST_DIR=./chroma_db  # ChromaDB local persistence directory
AGENT_HUMAN_REVIEW_THRESHOLD=0.7  # Claude confidence below this → requires_human_review=True
AGENT_POLL_INTERVAL=10       # Seconds between Alert table polls
LOG_LEVEL=INFO
